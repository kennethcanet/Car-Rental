@host = http://localhost:5250

# ── Tokens (auto-set after running the Login requests below) ─────────────────
@adminToken   = {{loginAdmin.response.body.$.accessToken}}
@adminRefresh = {{loginAdmin.response.body.$.refreshToken}}
@accessToken  = {{loginCustomer.response.body.$.accessToken}}
@refreshToken = {{loginCustomer.response.body.$.refreshToken}}

# ── Resource IDs (auto-set after running the Create requests below) ───────────
@locationId = {{createLocation.response.body.$.id}}
@vehicleId  = {{createVehicle.response.body.$.id}}
@bookingId  = {{createBooking.response.body.$.id}}


### ─────────────────────────────────────────────
###  AUTH
### ─────────────────────────────────────────────

### Login — Dev Admin  (seeded automatically in Development)
# @name loginAdmin
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@carrental.dev",
  "password": "Admin1234!"
}

###

### Register — Customer
POST {{host}}/auth/register
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Doe",
  "email": "jane.doe@example.com",
  "password": "Secret1234"
}

###

### Login — Customer
# @name loginCustomer
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "jane.doe@example.com",
  "password": "Secret1234"
}

###

### Refresh token
POST {{host}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

### Revoke token
POST {{host}}/auth/revoke
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "refreshToken": "{{refreshToken}}"
}


### ─────────────────────────────────────────────
###  LOCATIONS
### ─────────────────────────────────────────────

### List all locations
GET {{host}}/locations
Accept: application/json

###

### Get location by ID
GET {{host}}/locations/{{locationId}}
Accept: application/json

###

### Create location  (Admin)
# @name createLocation
POST {{host}}/locations
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Manila Airport Branch 3",
  "address": "NAIA Terminal 3, Pasay",
  "city": "Manila",
  "country": "Philippines"
}

###

### Update location  (Admin)
PUT {{host}}/locations/{{locationId}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Manila Airport Branch (Updated)",
  "address": "NAIA Terminal 3, Pasay City",
  "city": "Manila",
  "country": "Philippines"
}

###

### Delete location  (Admin)
# 409 if location has active vehicles
DELETE {{host}}/locations/{{locationId}}
Authorization: Bearer {{adminToken}}


### ─────────────────────────────────────────────
###  VEHICLES
### ─────────────────────────────────────────────

### List vehicles
GET {{host}}/vehicles?page=1&pageSize=10
Accept: application/json

###

### List vehicles — filter by location + category
GET {{host}}/vehicles?locationId={{locationId}}&category=SUV&page=1&pageSize=10
Accept: application/json

###

### List vehicles — availability filter
GET {{host}}/vehicles?availableFrom=2026-05-01T00:00:00Z&availableTo=2026-05-07T00:00:00Z&page=1&pageSize=10
Accept: application/json

###

### Get vehicle by ID
GET {{host}}/vehicles/{{vehicleId}}
Accept: application/json

###

### Create vehicle  (Admin)
# @name createVehicle
POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "make": "Toyota",
  "model": "Fortuner",
  "year": 2024,
  "category": "SUV",
  "dailyRate": 3500.00,
  "locationId": "{{locationId}}",
  "description": "7-seater 4x4 SUV, perfect for road trips"
}

###

### Update vehicle  (Admin)
PUT {{host}}/vehicles/{{vehicleId}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "make": "Toyota",
  "model": "Fortuner",
  "year": 2024,
  "category": "SUV",
  "dailyRate": 3800.00,
  "locationId": "{{locationId}}",
  "description": "7-seater 4x4 SUV — updated rate"
}

###

### Delete vehicle  (Admin)
# 409 if vehicle has active bookings
DELETE {{host}}/vehicles/{{vehicleId}}
Authorization: Bearer {{adminToken}}


### ─────────────────────────────────────────────
###  BOOKINGS
### ─────────────────────────────────────────────

### Create booking
# @name createBooking
POST {{host}}/bookings
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "vehicleId": "{{vehicleId}}",
  "pickupAt": "2026-05-01T08:00:00Z",
  "returnAt": "2026-05-07T08:00:00Z",
  "notes": "Please have the car washed before pickup."
}

###

### List bookings  (Customers see own; Admins see all)
GET {{host}}/bookings
Accept: application/json
Authorization: Bearer {{accessToken}}

###

### Get booking by ID
GET {{host}}/bookings/{{bookingId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

###

### Cancel booking
# 400 if booking is Active, Completed, or already Cancelled
POST {{host}}/bookings/{{bookingId}}/cancel
Authorization: Bearer {{accessToken}}
